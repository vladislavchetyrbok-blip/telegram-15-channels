LOCAL_AI_PROVIDER=lmstudio
LOCAL_AI_BASE_URL=http://localhost:1234/v1
LOCAL_AI_MODEL=local-model
LOCAL_AI_TEMPERATURE=0.7
LOCAL_AI_MAX_TOKENS=800

TELEGRAM_BOT_MODE=single_bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_DRY_RUN=false
TELEGRAM_REAL_PUBLISH_ENABLED=false
ADMIN_TELEGRAM_CHAT_ID=
ADMIN_REPORTS_ENABLED=true
DATABASE_URL=
OPENAI_API_KEY=
PUBLISH_DUE_STORE=json
PUBLISH_DUE_DRY_RUN=true
PUBLISH_DUE_MAX_PER_RUN=1

AUTOPUBLISH_WEEKLY_ENABLED=true
AUTOPUBLISH_DAYS=2,5
AUTOPUBLISH_TIME=11:00
AUTOPUBLISH_TIMEZONE=Europe/Kyiv

APP_ENV=local
APP_URL=http://localhost:3000

IMAGE_PROVIDER=local_template
IMAGE_AI_ENABLED=false
IMAGE_GENERATION_MODE=template_first
IMAGE_HARDWARE_PROFILE=low
IMAGE_WIDTH=1080
IMAGE_HEIGHT=1350
